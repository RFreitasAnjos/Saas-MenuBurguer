# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/foodburguer?schema=public"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 Storage ────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── InfinitePay ───────────────────────────────────────────────────────────────
INFINITEPAY_API_KEY=
INFINITEPAY_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
